# JTDOS Alpha 0.1 staging reverse proxy example
#
# Example domain:
#   staging.example.com
#
# Upstream app:
#   http://127.0.0.1:3000
#
# HTTPS should be managed by Certbot, your cloud platform, or your load balancer.
# Do not paste production secrets into this file.

server {
    listen 80;
    server_name staging.example.com;

    # If Certbot manages HTTPS, it may add ACME challenge blocks here.
    # After HTTPS is configured, redirect HTTP to HTTPS.
    # return 301 https://$host$request_uri;

    client_max_body_size 2m;

    location /ai-booking {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Internal config check should not be publicly accessible.
    # Replace 203.0.113.10 with your office / VPN / trusted IP.
    location /internal/config-check {
        # allow 203.0.113.10;
        # deny all;

        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# HTTPS server block example after Certbot/platform certificate setup:
#
# server {
#     listen 443 ssl http2;
#     server_name staging.example.com;
#
#     ssl_certificate /etc/letsencrypt/live/staging.example.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/staging.example.com/privkey.pem;
#
#     include snippets/jtdos_staging_locations.conf;
# }
